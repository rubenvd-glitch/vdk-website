# Copy this file to .env and fill in your values

# The only email allowed to log in to the admin panel
ADMIN_EMAIL=info@vdkbusiness-services.nl

# Random long string, used to sign session cookies (change this!)
SESSION_SECRET=change-this-to-a-long-random-string

# SMTP settings of your own mailbox (ask your email provider for these)
SMTP_HOST=mail.vdkbusiness-services.nl
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@vdkbusiness-services.nl
SMTP_PASS=your-mailbox-password

# From-address for the 2FA codes
MAIL_FROM=info@vdkbusiness-services.nl

# Set to "production" when deployed (enables secure cookies)
NODE_ENV=development

PORT=3000
